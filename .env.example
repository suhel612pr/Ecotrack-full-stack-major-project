# Supabase Client Configuration
# Required for real-time database transactions, supervisor controls, task dispatching, and secure user logins.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Backend Service Keys (Secrets)
# These keys are NOT used by the Vite client. They must be set as secrets
# in your Supabase project dashboard under Functions -> Settings.
GROQ_API_KEY="your-groq-api-key"
RESEND_API_KEY="your-resend-api-key"
